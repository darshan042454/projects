
#include <Arduino.h>
#include <WiFi.h>
#include <ArduinoOTA.h>
#include <WebServer.h>
#include <WebSocketsServer.h>

WebServer server(80);
WebSocketsServer webSocket(81);   // WebSocket runs on its own port

const char* ssid = "wifiname ";
const char* password = "password";

const int LED_PIN = 2;
const int ge = 12, whi = 32, blue = 33, red = 26;

bool ledState[4] = {false, false, false, false};
int leds[4] = {red, blue, whi, ge};
String ledNames[4] = {"RED", "BLUE", "WHITE", "GREEN"};
const char* colors[4] = {"#E24B4A", "#378ADD", "#D3D1C7", "#639922"};

void broadcastState() {
    String json = "{\"states\":[";
    for (int i = 0; i < 4; i++) {
        json += ledState[i] ? "true" : "false";
        if (i < 3) json += ",";
    }
    json += "]}";
    webSocket.broadcastTXT(json);
}

void webSocketEvent(uint8_t num, WStype_t type, uint8_t* payload, size_t len) {
    switch (type) {
        case WStype_DISCONNECTED:
            Serial.printf("[WS %u] Disconnected\n", num);
            break;

        case WStype_CONNECTED: {
            IPAddress ip = webSocket.remoteIP(num);
            Serial.printf("[WS %u] Connected from %s\n", num, ip.toString().c_str());
            broadcastState();   // send current state to the newly connected client
            break;
        }

        case WStype_TEXT: {
            // payload is NOT guaranteed null-terminated -> copy safely
            char buf[16] = {0};
            size_t n = (len < sizeof(buf) - 1) ? len : sizeof(buf) - 1;
            memcpy(buf, payload, n);
            buf[n] = '\0';

            int ledNum = atoi(buf);
            Serial.printf("[WS %u] Toggle request for LED %d\n", num, ledNum);

            if (ledNum >= 0 && ledNum < 4) {
                ledState[ledNum] = !ledState[ledNum];
                digitalWrite(leds[ledNum], ledState[ledNum]);
                broadcastState();
            }
            break;
        }

        default:
            break;
    }
}

void handleRoot() {
    server.send(200, "text/plain", "Home Page");
}

void handleMotor() {
    server.send(200, "text/plain", "Motor Page");
}

void handleTemperature() {
    server.send(200, "text/plain", "Temperature Page");
}

